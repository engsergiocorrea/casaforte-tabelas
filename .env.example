# ============================================================
# Casa Forte | Tabelas de Vendas — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha com seus valores
# NUNCA comite o .env.local no git

# ── Supabase ─────────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NUNCA expor no cliente, apenas server-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Em produção: https://seudominio.com.br

# ── Vercel (preenchido automaticamente em produção) ───────────
# VERCEL_URL=
